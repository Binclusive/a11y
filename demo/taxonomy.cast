[44.263, "o", "  \u001b[38;5;36m\u001b[1m✓  0 problems\u001b[0m\u001b[38;5;245m   eslint says it's clean.\u001b[0m\r\n"]
[46.063, "o", "\u001b[38;5;245m  Clean — because \u001b[38;5;252m<Input>\u001b[38;5;245m is a component, and eslint can't look inside it.\u001b[0m\r\n"]
[51.983, "o", "\u001b[2J\u001b[H"]
[52.283, "o", "\u001b[38;5;176m\u001b[1m  ┄┄ a11y-checker, the very same file ┄┄\u001b[0m\r\n"]
[52.283, "o", "\r\n"]
[53.083, "o", "\u001b[38;5;245m  It resolves \u001b[38;5;252m<Input>\u001b[38;5;245m down to a real \u001b[38;5;252m<input>\u001b[38;5;245m, then reads the call site.\u001b[0m\r\n"]
