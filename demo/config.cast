[41.496, "o", "g"]
[41.54, "o", "e"]
[41.572, "o", "s"]
[41.604, "o", "t"]
[41.636, "o", "\r\n"]
[42.336, "o", "  \u001b[38;5;252m  suggested \u001b[38;5;221m\u001b[1m30\u001b[0m\u001b[38;5;252m component mappings (review them — especially the ⚠):\u001b[0m\r\n"]
[42.376, "o", "    \u001b[38;5;252mAddressInput            \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150minput\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.416, "o", "    \u001b[38;5;252mArrowButton             \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150mbutton\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.456, "o", "    \u001b[38;5;252mAvatar                  \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150mimg\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.496, "o", "    \u001b[38;5;252mButton                  \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150mbutton\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.536, "o", "    \u001b[38;5;252mButtonOrLink            \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150ma\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.576, "o", "    \u001b[38;5;252mCheckboxField           \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150minput\u001b[0m\u001b[38;5;36m  ✓\u001b[0m\r\n"]
[42.616, "o", "    \u001b[38;5;252mSelect                  \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150mselect\u001b[0m\u001b[38;5;221m  ⚠ \u001b[0m\u001b[38;5;245mverify — could be a custom widget, not a native <select>\u001b[0m\r\n"]
[42.656, "o", "    \u001b[38;5;252mLocationSelect          \u001b[0m\u001b[38;5;245m→ \u001b[38;5;150mselect\u001b[0m\u001b[38;5;221m  ⚠ \u001b[0m\u001b[38;5;245mverify — could be a custom widget, not a native <select>\u001b[0m\r\n"]
[42.696, "o", "  \u001b[38;5;245m    … +22 more — eyeball the ⚠ before committing\u001b[0m\r\n"]
[42.736, "o", "\r\n"]
[44.336, "o", "\u001b[38;5;245m  It guessed a host for every primitive — \u001b[38;5;36m✓\u001b[38;5;245m confident, \u001b[38;5;221m⚠\u001b[38;5;245m review the uncertain.\u001b[0m\r\n"]
[49.539, "o", "\u001b[38;5;245m  Composites with no single host stay in declare. A 2-minute review, not hand-config.\u001b[0m\r\n"]
[54.594, "o", "\u001b[2J\u001b[H"]
[54.894, "o", "\u001b[38;5;252m\u001b[1m  the written components map\u001b[0m\u001b[38;5;245m  (your word overrides inference)\u001b[0m\r\n"]
[54.894, "o", "\r\n"]
[55.494, "o", "  \u001b[38;5;81m\"components\"\u001b[0m: {\r\n"]
[55.494, "o", "  \u001b[38;5;81m  \"AddressInput\": \"input\",\u001b[0m\r\n"]
[55.554, "o", "  \u001b[38;5;81m  \"ArrowButton\": \"button\",\u001b[0m\r\n"]
[55.614, "o", "  \u001b[38;5;81m  \"Avatar\": \"img\",\u001b[0m\r\n"]
[55.674, "o", "  \u001b[38;5;81m  \"Button\": \"button\",\u001b[0m\r\n"]
[55.734, "o", "  \u001b[38;5;81m  \"ButtonOrLink\": \"a\",\u001b[0m\r\n"]
[55.794, "o", "  \u001b[38;5;81m  \"CheckboxField\": \"input\",\u001b[0m\r\n"]
[55.854, "o", "  \u001b[38;5;81m  \"CommandInput\": \"input\",\u001b[0m\r\n"]
[55.914, "o", "  \u001b[38;5;81m  \"EmailField\": \"input\",\u001b[0m\r\n"]
[55.974, "o", "  \u001b[38;5;81m  \"FilterSearchField\": \"input\",\u001b[0m\r\n"]
[56.034, "o", "  \u001b[38;5;245m  … +21 more\u001b[0m\r\n"]
[56.094, "o", "  }\r\n"]
[56.094, "o", "\r\n"]
[58.294, "o", "\u001b[2J\u001b[H"]
[58.594, "o", "\u001b[38;5;213m\u001b[1m  PART 4/6\u001b[0m  \u001b[38;5;252m\u001b[1mTwo escape hatches for the edge cases\u001b[0m\r\n"]
[58.594, "o", "\u001b[38;5;245m  ───────────────────────────────────────────────────\u001b[0m\r\n"]
[58.594, "o", "\r\n"]
[59.294, "o", "\u001b[38;5;245m  When auto-detection can't be right, you get the final word:\u001b[0m\r\n"]
[61.917, "o", "\r\n"]
[61.917, "o", "  \u001b[38;5;81m\"injectsChildren\"\u001b[0m: [\u001b[38;5;150m\"Trans\"\u001b[0m, \u001b[38;5;150m\"FormattedMessage\"\u001b[0m],\u001b[38;5;245m   ← i18n text helpers\u001b[0m\r\n"]
[61.917, "o", "     \u001b[38;5;245m↳ \u001b[38;5;252mTrans\u001b[38;5;245m (react-i18next) · \u001b[38;5;252mFormattedMessage\u001b[38;5;245m (react-intl) inject text at RUNTIME.\u001b[0m\r\n"]
[61.917, "o", "       \u001b[38;5;245mTrans is built-in — declare \u001b[38;5;252myour own\u001b[38;5;245m Trans-like wrappers so kids aren't flagged 'empty'.\u001b[0m\r\n"]
[61.917, "o", "\r\n"]
[64.117, "o", "  \u001b[38;5;81m\"ignore\"\u001b[0m: [\u001b[38;5;150m\"**/*.stories.tsx\"\u001b[0m, \u001b[38;5;150m\"jsx-a11y/no-autofocus\"\u001b[0m]\r\n"]
[64.117, "o", "     \u001b[38;5;245m↳ a file glob drops the file · a rule id drops that rule everywhere\u001b[0m\r\n"]
[64.117, "o", "\r\n"]
[66.517, "o", "\u001b[38;5;245m  Every hatch is optional and parsed leniently — one bad line is dropped, never the whole file.\u001b[0m\r\n"]
[72.402, "o", "\u001b[2J\u001b[H"]
[72.702, "o", "\u001b[38;5;213m\u001b[1m  PART 5/6\u001b[0m  \u001b[38;5;252m\u001b[1mlearned — teach it your team's rules\u001b[0m\r\n"]
[72.702, "o", "\u001b[38;5;245m  ──────────────────────────────────────────────────\u001b[0m\r\n"]
[72.702, "o", "\r\n"]
[73.402, "o", "\u001b[38;5;245m  Record a rule once; it rides into every AI turn via the generated AGENTS.md / CLAUDE.md.\u001b[0m\r\n"]
[77.272, "o", "\r\n"]
