[87.348, "o", "\u001b[2J\u001b[H"]
[87.648, "o", "\u001b[38;5;213m\u001b[1m  PART 6/6\u001b[0m  \u001b[38;5;252m\u001b[1mSafe to re-run · safe to commit\u001b[0m\r\n"]
[87.648, "o", "\u001b[38;5;245m  ─────────────────────────────────────────────\u001b[0m\r\n"]
[87.648, "o", "\r\n"]
[88.348, "o", "\u001b[38;5;245m  Re-running init refreshes only the auto-detected \u001b[38;5;252mstack\u001b[38;5;245m.\u001b[0m\r\n"]
[91.745, "o", "\u001b[38;5;245m  Your \u001b[38;5;252menforcement\u001b[38;5;245m, \u001b[38;5;252mcomponents\u001b[38;5;245m, \u001b[38;5;252mlearned\u001b[38;5;245m, and hatches are preserved byte-for-byte.\u001b[0m\r\n"]
[98.066, "o", "\r\n"]
[99.466, "o", "  \u001b[38;5;36m✓\u001b[0m\u001b[38;5;245m  no secret or API key ever lands here — it's plain config\u001b[0m\r\n"]
[99.466, "o", "  \u001b[38;5;36m✓\u001b[0m\u001b[38;5;245m  committed to your git · read by the CLI, the MCP server, and your agent\u001b[0m\r\n"]
[99.466, "o", "  \u001b[38;5;36m✓\u001b[0m\u001b[38;5;245m  nothing leaves the machine\u001b[0m\r\n"]
[99.466, "o", "\r\n"]
[101.466, "o", "\u001b[2J\u001b[H"]
[101.866, "o", "\r\n"]
[101.866, "o", "\u001b[1m\u001b[38;5;252m  stack · enforcement · components · injectsChildren · ignore · learned\u001b[0m\r\n"]
[103.666, "o", "\u001b[38;5;245m  one file. detected for you, tuned by you, committed with your code.\u001b[0m\r\n"]
[104.866, "o", "\r\n"]
[104.866, "o", "  \u001b[38;5;245mfull field reference:\u001b[0m \u001b[38;5;44msrc/contract.ts\u001b[0m\u001b[38;5;245m  ·  \u001b[0m\u001b[38;5;44mdocs/GETTING-STARTED.md\u001b[0m\r\n"]
