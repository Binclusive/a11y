[80.566, "o", "\u001b[38;5;36m  \u001b[0m\u001b[38;5;245m    --wcag 4.1.2 --fix \"Add aria-label to icon-only controls\"\u001b[0m\r\n"]
[81.166, "o", "  \u001b[38;5;36mlearned \"icon-only-buttons-must-have-an-aria-label\" → binclusive.json\u001b[0m\r\n"]
[81.246, "o", "  \u001b[38;5;245m  block: AGENTS.md\u001b[0m\r\n"]
[81.326, "o", "  \u001b[38;5;245m  block: CLAUDE.md\u001b[0m\r\n"]
[81.406, "o", "\r\n"]
[82.606, "o", "\u001b[38;5;245m  …appended to learned[] as structured data:\u001b[0m\r\n"]
[84.498, "o", "\r\n"]
[84.498, "o", "  \u001b[38;5;245m{\u001b[0m\r\n"]
[84.548, "o", "  \u001b[38;5;245m  \u001b[38;5;81m\"id\"\u001b[0m: \"icon-only-buttons-must-have-an-aria-label\",\u001b[0m\r\n"]
[84.598, "o", "  \u001b[38;5;245m  \u001b[38;5;81m\"rule\"\u001b[0m: \"Icon-only buttons must have an aria-label\",\u001b[0m\r\n"]
[84.648, "o", "  \u001b[38;5;245m  \u001b[38;5;81m\"wcag\"\u001b[0m: [\u001b[0m\r\n"]
[84.698, "o", "  \u001b[38;5;245m    \"4.1.2\"\u001b[0m\r\n"]
[84.748, "o", "  \u001b[38;5;245m  ],\u001b[0m\r\n"]
[84.798, "o", "  \u001b[38;5;245m  \u001b[38;5;81m\"fix\"\u001b[0m: \"Add aria-label to icon-only controls\",\u001b[0m\r\n"]
[84.848, "o", "  \u001b[38;5;245m  \u001b[38;5;81m\"source\"\u001b[0m: \"manual\"\u001b[0m\r\n"]
[84.898, "o", "  \u001b[38;5;245m}\u001b[0m\r\n"]
