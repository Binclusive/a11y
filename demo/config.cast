[0.0, "o", "\u001b[2J\u001b[H"]
[0.3, "o", "\u001b[1m\u001b[38;5;44m  binclusive.json — your accessibility contract, explained\u001b[0m\r\n"]
[0.9, "o", "\u001b[38;5;245m  one committed file · no secrets, ever · the lever between 'noisy' and 'enforced'\u001b[0m\r\n"]
[3.5, "o", "\u001b[2J\u001b[H"]
[3.8, "o", "\u001b[38;5;213m\u001b[1m  PART 1/6\u001b[0m  \u001b[38;5;252m\u001b[1mWhat init writes\u001b[0m\r\n"]
[3.8, "o", "\u001b[38;5;245m  ──────────────────────────────\u001b[0m\r\n"]
[3.8, "o", "\r\n"]
[4.5, "o", "\u001b[38;5;245m  You don't hand-author this. init detects your stack and writes the base contract:\u001b[0m\r\n"]
[8.069, "o", "\r\n"]
[8.069, "o", "  \u001b[38;5;245m{\u001b[0m\r\n"]
[8.069, "o", "  \u001b[38;5;81m\"version\"\u001b[0m: \u001b[38;5;221m1\u001b[0m                                        \u001b[38;5;245m← schema version\u001b[0m\r\n"]
[8.249, "o", "  \u001b[38;5;81m\"stack\"\u001b[0m: {                                          \u001b[38;5;245m← auto-detected — never hand-write\u001b[0m\r\n"]
[8.429, "o", "    \u001b[38;5;81m\"framework\"\u001b[0m: \u001b[38;5;150m\"next\"\u001b[0m, \u001b[38;5;81m\"router\"\u001b[0m: \u001b[38;5;150m\"app\"\u001b[0m, \u001b[38;5;81m\"designSystem\"\u001b[0m: \u001b[38;5;150m\"@calcom/ui\"\u001b[0m, \u001b[38;5;81m\"language\"\u001b[0m: \u001b[38;5;150m\"ts\"\u001b[0m\r\n"]
[8.729, "o", "  \u001b[38;5;245m  },\u001b[0m\r\n"]
[8.729, "o", "  \u001b[38;5;81m\"enforcement\"\u001b[0m: { \u001b[38;5;245mblock / warn\u001b[0m },                    \u001b[38;5;245m← the lever you own — Part 2\u001b[0m\r\n"]
[8.909, "o", "  \u001b[38;5;81m\"learned\"\u001b[0m: []                                       \u001b[38;5;245m← your team's rules — Part 5\u001b[0m\r\n"]
[9.089, "o", "  \u001b[38;5;81m\"components\"\u001b[0m: { … }                                 \u001b[38;5;245m← your design system — Part 3\u001b[0m\r\n"]
[9.269, "o", "  \u001b[38;5;245m}\u001b[0m\r\n"]
[9.269, "o", "\r\n"]
[10.669, "o", "\u001b[38;5;245m  Commit it. Your whole team — and every AI tool — reads the same contract.\u001b[0m\r\n"]
[15.494, "o", "\u001b[2J\u001b[H"]
[15.794, "o", "\u001b[38;5;213m\u001b[1m  PART 2/6\u001b[0m  \u001b[38;5;252m\u001b[1menforcement — what fails the build\u001b[0m\r\n"]
[15.794, "o", "\u001b[38;5;245m  ────────────────────────────────────────────────\u001b[0m\r\n"]
[15.794, "o", "\r\n"]
[16.494, "o", "\u001b[38;5;245m  Two buckets of WCAG criteria. This is the only policy dial you turn:\u001b[0m\r\n"]
[19.504, "o", "\r\n"]
[19.504, "o", "  \u001b[38;5;81m\"enforcement\"\u001b[0m: {\r\n"]
[19.504, "o", "  \u001b[38;5;81m\"block\"\u001b[0m: [\u001b[38;5;150m\"1.3.1\", \"4.1.2\", \"2.4.4\"\u001b[0m],               \u001b[38;5;245m← \u001b[38;5;203mFAIL the build (CI red)\u001b[38;5;245m\u001b[0m\r\n"]
[19.684, "o", "  \u001b[38;5;81m\"warn\"\u001b[0m:  [\u001b[38;5;150m\"1.1.1\", \"2.1.1\", \"3.3.2\", \"2.4.1\", …\u001b[0m]    \u001b[38;5;245m← \u001b[38;5;221msurface, don't block\u001b[38;5;245m\u001b[0m\r\n"]
[19.864, "o", "  }\r\n"]
[19.864, "o", "\r\n"]
[21.664, "o", "\u001b[38;5;245m  Want missing alt-text to block too? Move one criterion across:\u001b[0m\r\n"]
[24.416, "o", "\r\n"]
[24.416, "o", "  \u001b[38;5;203m-   \"warn\":  [\"1.1.1\", …]\u001b[0m\r\n"]
[24.416, "o", "  \u001b[38;5;36m+   \"block\": [\"1.1.1\", \"1.3.1\", \"4.1.2\", \"2.4.4\"]\u001b[0m\u001b[38;5;245m   ← 1.1.1 now stops the build\u001b[0m\r\n"]
[24.416, "o", "\r\n"]
[26.416, "o", "\u001b[38;5;245m  A criterion lives in at most one bucket — if you list it in both, block wins.\u001b[0m\r\n"]
[31.613, "o", "\u001b[2J\u001b[H"]
[31.913, "o", "\u001b[38;5;213m\u001b[1m  PART 3/6\u001b[0m  \u001b[38;5;252m\u001b[1mcomponents — see through your design system\u001b[0m\r\n"]
[31.913, "o", "\u001b[38;5;245m  ─────────────────────────────────────────────────────────\u001b[0m\r\n"]
[31.913, "o", "\r\n"]
[32.613, "o", "\u001b[38;5;245m  jsx-a11y only understands host tags (button, input, a). Your <Button> is opaque —\u001b[0m\r\n"]
[36.182, "o", "\u001b[38;5;245m  so you map each primitive to the host it renders. You don't write 30 of these by hand:\u001b[0m\r\n"]
[39.966, "o", "\r\n"]
[40.366, "o", "\u001b[38;5;36m❯ \u001b[0m"]
[40.366, "o", "n"]
