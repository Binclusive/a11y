[26.06, "o", "  \u001b[38;5;245ma11y-checker init — apps/web\u001b[0m\r\n"]
[26.11, "o", "  \u001b[38;5;245m  \u001b[38;5;44mstack:\u001b[38;5;245m       \u001b[38;5;252mnext (app router)\u001b[38;5;245m · \u001b[38;5;221m\u001b[1m@calcom/ui\u001b[0m\u001b[38;5;245m · ts\u001b[0m\r\n"]
[26.16, "o", "  \u001b[38;5;245m  \u001b[38;5;44menforcement:\u001b[38;5;245m block 1.3.1, 4.1.2, 2.4.4\u001b[0m\r\n"]
