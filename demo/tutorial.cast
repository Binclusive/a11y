[0.0, "o", "\u001b[2J\u001b[H"]
[0.3, "o", "\u001b[1m\u001b[38;5;44m  a11y-checker · getting started\u001b[0m\r\n"]
[0.9, "o", "\u001b[38;5;245m  zero to your first accessibility fix — on a real monorepo (calcom/cal.com).\u001b[0m\r\n"]
[0.9, "o", "\u001b[38;5;245m  everything runs on your machine. no account. your code never leaves the laptop.\u001b[0m\r\n"]
[3.7, "o", "\u001b[2J\u001b[H"]
[4.0, "o", "\u001b[38;5;213m\u001b[1m  STEP 1/6\u001b[0m  \u001b[38;5;252m\u001b[1mInstall\u001b[0m\r\n"]
