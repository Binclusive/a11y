[43.523, "o", "  \u001b[38;5;245ma11y-checker — scanned \u001b[38;5;252m8\u001b[38;5;245m .tsx file(s) under apps/web/components/booking\u001b[0m\r\n"]
[43.573, "o", "  \u001b[38;5;245m  checked  \u001b[38;5;36m\u001b[1m3\u001b[0m\u001b[38;5;245m  — elements we inspected (findings come from here)\u001b[0m\r\n"]
[43.623, "o", "  \u001b[38;5;245m  declare  36  — unrecognized; declare in binclusive.json to inspect them:\u001b[0m\r\n"]
[43.673, "o", "  \u001b[38;5;252m\u001b[1m4 finding(s)   COMMON: 2  |  VERY COMMON: 2\u001b[0m\r\n"]
[43.723, "o", "  \u001b[38;5;245menforcement: \u001b[38;5;203m4 blocking\u001b[38;5;245m · 0 warning\u001b[0m\r\n"]
[43.773, "o", "\r\n"]
[45.173, "o", "\u001b[38;5;245m  Here's the monorepo win: \u001b[38;5;221m@calcom/ui\u001b[38;5;245m lives in packages/ui, on disk —\u001b[0m\r\n"]
[49.086, "o", "\u001b[38;5;245m  so it traces straight through your own components. \u001b[38;5;252m4 real findings\u001b[38;5;245m, zero declaration.\u001b[0m\r\n"]
[53.773, "o", "\u001b[38;5;245m  \u001b[38;5;245m(trusted = Radix guarantees the structure · declare = name the rest to go deeper)\u001b[0m\u001b[0m\r\n"]
[59.387, "o", "\u001b[2J\u001b[H"]
[59.687, "o", "\u001b[38;5;213m\u001b[1m  STEP 4/6\u001b[0m  \u001b[38;5;252m\u001b[1mRead a finding\u001b[0m\r\n"]
[59.687, "o", "\u001b[38;5;245m  ────────────────────────────\u001b[0m\r\n"]
[59.687, "o", "\r\n"]
[60.387, "o", "\u001b[38;5;245m  Every finding has the same four parts. Take this one — the cancel-booking note:\u001b[0m\r\n"]
[63.87, "o", "\r\n"]
[63.87, "o", "  \u001b[1m\u001b[38;5;252m  CancelBooking.tsx:66\u001b[0m\r\n"]
[63.92, "o", "  \u001b[38;5;245m    rule:   \u001b[38;5;176menforce/input-no-name\u001b[0m\u001b[38;5;245m  \u001b[38;5;203m\u001b[1m[block]\u001b[0m\u001b[38;5;245m  \u001b[38;5;44m\u001b[1m(call-site content check)\u001b[0m\u001b[38;5;245m\u001b[0m\r\n"]
[63.97, "o", "  \u001b[38;5;245m    wcag:   WCAG 1.3.1, WCAG 3.3.2\u001b[0m\r\n"]
[64.02, "o", "  \u001b[38;5;245m    Control resolves to a form input but has no associated label: no aria-label/aria-labelledby, no label/title prop, and no id to pair with a <label for>. Associate a real label (corpus: 1.3.1 / 3.3.2-form-control-no-name).\u001b[0m\r\n"]
[64.07, "o", "  \u001b[38;5;245m    severity: \u001b[38;5;203m\u001b[1mCRITICAL\u001b[0m\u001b[38;5;245m\u001b[0m\r\n"]
[64.12, "o", "  \u001b[38;5;245m    corpus: \u001b[38;5;221m[VERY COMMON]\u001b[38;5;245m SC 1.3.1 — \u001b[38;5;221m\u001b[1m22/26 orgs\u001b[0m\u001b[38;5;245m\u001b[0m\r\n"]
[64.17, "o", "  \u001b[38;5;36m    fix:    Use real semantics: associate every form field with a <label> via id (not placeholder-only); use <ul>/<li> or <table> for lists; wrap main content in <main> and footer in <footer>.\u001b[0m\r\n"]
[64.22, "o", "\r\n"]
[66.42, "o", "\u001b[38;5;245m  \u001b[38;5;176mrule\u001b[38;5;245m what broke   ·   \u001b[38;5;252mwcag\u001b[38;5;245m the criterion   ·   \u001b[38;5;221mcorpus\u001b[38;5;245m how common in real audits   ·   \u001b[38;5;36mfix\u001b[38;5;245m what worked\u001b[0m\r\n"]
[76.99, "o", "\u001b[2J\u001b[H"]
[77.29, "o", "\u001b[38;5;213m\u001b[1m  STEP 5/6\u001b[0m  \u001b[38;5;252m\u001b[1mFix it\u001b[0m\r\n"]
[77.29, "o", "\u001b[38;5;245m  ────────────────────\u001b[0m\r\n"]
[77.29, "o", "\r\n"]
[77.99, "o", "\u001b[38;5;245m  A placeholder is not a name. Give the field a real one — one line:\u001b[0m\r\n"]
[80.914, "o", "\r\n"]
[80.914, "o", "  \u001b[38;5;245mapps/web/components/booking/CancelBooking.tsx\u001b[0m\r\n"]
[80.914, "o", "  \u001b[38;5;245m  <TextArea\u001b[0m\r\n"]
[80.914, "o", "  \u001b[38;5;36m+   aria-label={t(\"internal_booking_note_description\")}\u001b[0m\r\n"]
[80.914, "o", "  \u001b[38;5;245m    rows={3}\u001b[0m\r\n"]
[80.914, "o", "  \u001b[38;5;245m    placeholder={t(\"internal_booking_note_description\")} />\u001b[0m\r\n"]
[80.914, "o", "\r\n"]
