[26.26, "o", "\r\n"]
[27.26, "o", "\u001b[38;5;245m  Next app-router, TypeScript — and it found your in-repo design system, \u001b[38;5;221m@calcom/ui\u001b[38;5;245m.\u001b[0m\r\n"]
[31.818, "o", "\u001b[38;5;245m  \u001b[38;5;252mbinclusive.json\u001b[38;5;245m is yours to commit. That's the whole setup.\u001b[0m\r\n"]
