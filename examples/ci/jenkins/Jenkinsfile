// a11y-checker on Jenkins — ready-made Declarative Pipeline.
//
// Runs the published Binclusive engine image over the .tsx files changed in each
// PR (multibranch), falling back to a diff vs the default branch.
//
// Image: ghcr.io/binclusive/a11y:<version>  (static / no-browser variant).
//   Bump the tag to upgrade. For a live-URL scan (set INPUT_SCAN_URL) swap to the
//   browser variant ghcr.io/binclusive/a11y:browser-<version> (legacy :<version>-browser still published).
//
// Canon: .patterns/ci-runners/{run-docker-image,ci-context,checkout-depth,secrets-and-env,exit-codes}.md

pipeline {
  // run-docker-image.md: `agent { docker { image } }` runs the stages in the
  // container on the executing node, with the Jenkins workspace mounted.
  agent {
    docker {
      image 'ghcr.io/binclusive/a11y:0.1.3' // x-release-please-version
      // Run as root so git trusts the mounted workspace (the entrypoint sets
      // safe.directory on it); the Docker container's .git is owned by the node.
      args '-u root:root'
    }
  }

  environment {
    A11Y_DEFAULT_BRANCH = 'main'
    // secrets-and-env.md: optional phone-home. Create a "Secret text" credential
    // with id 'b8e-token'; `credentials(...)` injects it MASKED into the build.
    // Absent -> keep this commented and the scan stays fully local.
    // B8E_TOKEN = credentials('b8e-token')
  }

  stages {
    stage('a11y-checker') {
      steps {
        // exit-codes.md: `sh` fails the build on a non-zero exit — how the opt-in
        // gate blocks. Default is advisory (exit 0). Soft-fail escape: wrap the
        // step in catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') { ... }.
        sh '''
          # ci-context.md: base = CHANGE_TARGET on a multibranch PR build, else the
          # default branch; head = GIT_COMMIT. checkout-depth.md: Jenkins clones
          # full by default, so a plain fetch of the base ref is enough.
          BASE_BRANCH="${CHANGE_TARGET:-$A11Y_DEFAULT_BRANCH}"
          # We run as root (`-u root:root`) over a workspace owned by the node user;
          # this fetch precedes the entrypoint, so mark the dir safe here too or git
          # aborts with "detected dubious ownership".
          git config --global --add safe.directory "$WORKSPACE"
          git fetch --no-tags origin "$BASE_BRANCH"
          export GITHUB_WORKSPACE="$WORKSPACE"
          export BASE_SHA="origin/$BASE_BRANCH"
          export HEAD_SHA="${GIT_COMMIT:-HEAD}"
          # Opt-in blocking gate (default OFF = advisory). Uncomment ONE:
          # export FAIL_ON=serious        # fail when any finding is >= this impact
          # export MAX_VIOLATIONS=0       # fail when total finding count exceeds N
          /engine/entrypoint.sh
        '''
      }
    }
  }
}
