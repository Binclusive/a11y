{
  "name": "@binclusive/a11y",
  "version": "0.1.0",
  "type": "module",
  "description": "Local accessibility checker for React/TSX, grounded in a real-world audit corpus. Runs entirely on your machine — no network, no upload.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "a11y-checker": "./bin/a11y.mjs"
  },
  "files": [
    "bin",
    "src",
    "data/corpus-snapshot.json",
    "data/corpus/patterns-*.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Binclusive/a11y-checker-plugin.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "scan": "tsx ./src/cli.ts check",
    "mcp": "tsx ./src/mcp.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo:lint": "sh -c 'tsx demo/demo-kit.ts lint \"${1:-demo/scenario.json}\"' _",
    "demo:play": "sh -c 'tsx demo/demo-kit.ts play \"${1:-demo/scenario.json}\" \"${@:2}\"' _",
    "demo:record": "sh -c 'tsx demo/demo-kit.ts record \"${1:-demo/scenario.json}\"' _",
    "matrix:discover": "tsx experiments/stack-matrix/discover.ts",
    "matrix:run": "tsx experiments/stack-matrix/run.ts",
    "matrix:report": "tsx experiments/stack-matrix/report.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "zod": "4.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "vitest": "3.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
