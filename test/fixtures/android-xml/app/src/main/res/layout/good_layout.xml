<?xml version="1.0" encoding="utf-8"?>
<!-- Negative cases: every element here is correctly labeled / decorative /
     suppressed, so NONE of them should produce a finding. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- labeled image: has a contentDescription -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/thumbnail_desc"
        android:src="@drawable/ic_thumb" />

    <!-- decorative image: contentDescription="@null" opts out of 1.1.1 -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_divider" />

    <!-- decorative image: importantForAccessibility="no" -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_spacer" />

    <!-- suppressed image: tools:ignore waives the ContentDescription check -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_ignored"
        tools:ignore="ContentDescription" />

    <!-- labeled control: ImageButton with a contentDescription -->
    <ImageButton
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/play_desc"
        android:src="@drawable/ic_play" />

    <!-- labeled control: Button with android:text -->
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/submit" />

    <!-- clickable container labeled by a text-bearing child (descendant-climb) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_row_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Row title set at runtime" />
    </LinearLayout>
</LinearLayout>
