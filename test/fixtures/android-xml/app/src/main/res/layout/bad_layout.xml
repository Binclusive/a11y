<?xml version="1.0" encoding="utf-8"?>
<!-- Positive cases: every element here SHOULD produce a finding. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- image-no-label: ImageView with a src but no contentDescription -->
    <ImageView
        android:id="@+id/thumbnail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_thumb" />

    <!-- image-no-label AND control-no-name: an unlabeled ImageButton is both -->
    <ImageButton
        android:id="@+id/play"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_play" />

    <!-- control-no-name: a Button with neither android:text nor contentDescription -->
    <Button
        android:id="@+id/action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- control-no-name: a clickable container whose only child is an unlabeled image -->
    <FrameLayout
        android:id="@+id/clickable_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_add"
            tools:ignore="ContentDescription" />
    </FrameLayout>
</LinearLayout>
