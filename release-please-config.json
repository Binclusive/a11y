{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "extra-files": [
        { "type": "generic", "path": "action.yml" },
        { "type": "generic", "path": "action-url/action.yml" },
        { "type": "generic", "path": "README.md" },
        { "type": "generic", "path": "docs/QUICKSTART-CI.md" },
        { "type": "generic", "path": "examples/github-actions/a11y.yml" },
        { "type": "generic", "path": "examples/github-actions/a11y-advanced.yml" },
        { "type": "generic", "path": "examples/ci/gitlab/.gitlab-ci.yml" },
        { "type": "generic", "path": "examples/ci/circleci/config.yml" },
        { "type": "generic", "path": "examples/ci/bitbucket/bitbucket-pipelines.yml" },
        { "type": "generic", "path": "examples/ci/jenkins/Jenkinsfile" },
        { "type": "generic", "path": "examples/ci/buildkite/pipeline.yml" }
      ]
    }
  }
}
