{
  "sc": "2.4.4",
  "clusters": [
    {
      "id": "2.4.4-link-no-name",
      "wcag": ["2.4.4"],
      "component": "icon / image / empty link",
      "failureShape": "A link has no accessible name — it wraps only an icon, SVG, or image with empty alt, or is an empty <a> with no text — so screen-reader users hear only \"link\" with no idea of its purpose or destination.",
      "fix": "Give every link a discernible accessible name: visible text, an aria-label, or alt text on the link's image that names the destination. Remove empty/decorative links from the tab order.",
      "journeyTags": ["navigation", "browse-discovery"]
    },
    {
      "id": "2.4.4-generic-link-text",
      "wcag": ["2.4.4"],
      "component": "non-descriptive link",
      "failureShape": "A link's text is generic and uninformative out of context (\"click here\", \"more info\", \"read more\", \"details\", \"view more\"), often repeated identically across the page, so its purpose and destination aren't conveyed.",
      "fix": "Write link text that describes the destination on its own, or add a unique aria-label / visually hidden suffix so repeated links are distinguishable (e.g. \"Read more about admissions\").",
      "journeyTags": ["browse-discovery", "content-consumption", "product-detail"]
    },
    {
      "id": "2.4.4-noisy-or-wrong-name",
      "wcag": ["2.4.4"],
      "component": "link with polluted name",
      "failureShape": "A link's accessible name is noise or wrong — a raw URL, a build/slug prefix, a stray symbol, an over-long auto-generated description, or alt text that contradicts the destination — so the announced name doesn't match the link's purpose.",
      "fix": "Set a clean, accurate accessible name that matches the destination. Strip URLs, technical prefixes, and stray glyphs from the name; fix image alt text inside links so it describes where the link goes.",
      "journeyTags": ["browse-discovery", "navigation"]
    },
    {
      "id": "2.4.4-social-icon-link-no-name",
      "wcag": ["2.4.4"],
      "component": "social media icon link",
      "failureShape": "Social media links (Facebook, Instagram, YouTube, etc.) carry only an icon glyph or SVG with no accessible name, so the platform they link to isn't conveyed.",
      "fix": "Give each social link an aria-label naming the platform (e.g. aria-label=\"Instagram\"), or add visually hidden text. Mark the icon itself aria-hidden=\"true\".",
      "journeyTags": ["navigation", "browse-discovery"]
    },
    {
      "id": "2.4.4-target-not-signaled",
      "wcag": ["2.4.4"],
      "component": "link to file / new context",
      "failureShape": "A link that opens a PDF, an external site, or a new window/tab doesn't signal that in its accessible name, so users can't anticipate the file type or context change before activating it.",
      "fix": "Include the target behavior in the link's accessible name: append \"(PDF)\", \"(opens in a new window)\", or \"(external)\" via the link text or an aria-label.",
      "journeyTags": ["content-consumption", "navigation"]
    }
  ],
