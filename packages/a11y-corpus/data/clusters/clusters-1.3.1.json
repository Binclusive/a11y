{
  "sc": "1.3.1",
  "clusters": [
    {
      "id": "1.3.1-content-not-in-a11y-tree",
      "wcag": ["1.3.1"],
      "component": "main content region",
      "failureShape": "Content that is visible on screen (article text, cards, list items, prices, navigation) is missing from the accessibility tree, so screen-reader users cannot reach or hear it — often because a wrapper carries aria-hidden=\"true\", display is mismanaged on injected content, or dynamic content never renders into the tree.",
      "fix": "Make sure meaningful content is exposed to assistive tech: never put aria-hidden=\"true\" on a container that holds real content, render route-changed/dynamically loaded content into the DOM and accessibility tree, and verify the main region is reachable in screen-reader browse mode. Manage focus to newly revealed content.",
      "journeyTags": ["content-consumption", "browse-discovery"]
    },
    {
      "id": "1.3.1-form-control-no-programmatic-label",
      "wcag": ["1.3.1"],
      "component": "form input",
      "failureShape": "A form input (text field, combobox, date picker, textarea) has no programmatically associated label — it relies on a placeholder or nearby visual text — so assistive tech announces it without a name or with the wrong name.",
      "fix": "Associate every input with a real label: a <label for> matching the input id, or aria-label / aria-labelledby. Never rely on placeholder as the accessible name. For custom comboboxes, also link the visible label to the widget.",
      "journeyTags": ["form-submission", "sign-in", "checkout"]
    },
    {
      "id": "1.3.1-heading-structure-broken",
      "wcag": ["1.3.1"],
      "component": "page headings",
      "failureShape": "The page's top-level heading structure is wrong: no H1, multiple H1s, the page starts at H2, or visually prominent headings are not marked up as headings at all — so screen-reader users get no reliable map of the page.",
      "fix": "Give each page exactly one H1 that names its main topic, mark every visual heading with a real heading tag, and reserve lower levels (H2–H6) for subsections. Don't use multiple H1s for sibling sections.",
      "journeyTags": ["browse-discovery", "content-consumption"]
    },
    {
      "id": "1.3.1-skipped-heading-levels",
      "wcag": ["1.3.1"],
      "component": "heading hierarchy",
      "failureShape": "Heading levels are non-sequential — the page jumps levels (e.g. H1 to H3, H2 to H6) or nests them out of order, so the heading outline misrepresents the document structure.",
      "fix": "Nest headings sequentially without skipping levels (H1 then H2 then H3…). Pick the level by the section's place in the outline, not by its visual size; use CSS for sizing.",
      "journeyTags": ["content-consumption", "browse-discovery"]
    },
    {
      "id": "1.3.1-tabular-data-no-table",
      "wcag": ["1.3.1"],
      "component": "tabular data",
      "failureShape": "Tabular data (prices, rates, schedules, comparisons) is built from <div>s or plain text instead of a real table, or a table lacks header semantics, so screen-reader users can't tie a value to its row/column header.",
      "fix": "Mark up tabular data with a semantic <table>: <thead> with <th scope> header cells, <tbody> with <td> data cells, and a <caption> naming the table's purpose. Don't fake tables with divs.",
      "journeyTags": ["product-detail", "content-consumption"]
    },
    {
      "id": "1.3.1-missing-landmarks",
      "wcag": ["1.3.1"],
      "component": "page landmarks",
      "failureShape": "The page lacks landmark regions (no <main>, <nav>, <header>, or <footer>), so screen-reader users can't jump to the primary content or navigate by region.",
      "fix": "Wrap major page sections in HTML5 landmarks: <main> for primary content, <nav> for navigation, <header>/<footer> (banner/contentinfo) for the page chrome. One main landmark per page.",
      "journeyTags": ["navigation", "browse-discovery"]
    },
    {
      "id": "1.3.1-list-not-marked-up",
      "wcag": ["1.3.1"],
      "component": "list of items",
      "failureShape": "A visual list (navigation groups, benefits, cards, track lists) is built from generic elements instead of list markup, so screen-reader users don't hear it as a list or get an item count.",
      "fix": "Mark up lists with <ul>/<ol> and <li> so assistive tech announces the list and its length. Group each repeated item in its own <li>.",
      "journeyTags": ["browse-discovery", "navigation"]
    },
    {
      "id": "1.3.1-landmark-no-unique-name",
      "wcag": ["1.3.1"],
      "component": "navigation landmark",
      "failureShape": "Multiple navigation or region landmarks share no unique accessible name, so screen-reader users can't tell main navigation from footer or breadcrumb navigation when listing landmarks.",
      "fix": "Give each repeated landmark a unique aria-label or aria-labelledby (e.g. \"Main navigation\", \"Footer navigation\") describing its purpose.",
      "journeyTags": ["navigation"]
    },
    {
      "id": "1.3.1-empty-heading",
      "wcag": ["1.3.1"],
      "component": "heading element",
      "failureShape": "A heading element contains no text, so it introduces a section with no information and pollutes the heading outline.",
      "fix": "Remove empty heading tags, or give the section a descriptive heading. Don't use empty headings purely for spacing or styling.",
      "journeyTags": ["content-consumption"]
    },
    {
      "id": "1.3.1-heading-for-body-text",
      "wcag": ["1.3.1"],
      "component": "body paragraph",
      "failureShape": "Heading tags are used for ordinary body text (paragraphs marked as H3, etc.), so the heading outline is flooded with non-headings and real structure is lost.",
      "fix": "Use <p> for body text and reserve heading tags for actual section titles. Style paragraphs with CSS instead of borrowing heading levels for emphasis.",
      "journeyTags": ["content-consumption"]
    }
  ],
